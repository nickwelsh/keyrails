{
	"name": "keyrails",
	"version": "0.1.0",
	"private": false,
	"description": "Key-configurable CRUD and relation helpers for Replicache",
	"keywords": [
		"crud",
		"relations",
		"replicache",
		"typescript"
	],
	"homepage": "https://github.com/nickwelsh/keyrails",
	"bugs": {
		"url": "https://github.com/nickwelsh/keyrails/issues"
	},
	"license": "Apache-2.0",
	"author": "",
	"repository": {
		"type": "git",
		"url": "https://github.com/nickwelsh/keyrails.git"
	},
	"files": [
		"dist/",
		"!dist/*.test.*"
	],
	"type": "module",
	"sideEffects": false,
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		}
	},
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"scripts": {
		"fmt": "oxfmt",
		"fmt:check": "oxfmt --check",
		"check-types": "tsgo --noEmit",
		"lint": "oxlint --deny-warnings src",
		"lint:fix": "oxlint --fix src",
		"build": "tsgo",
		"changeset": "changeset",
		"version-packages": "changeset version && bun install --frozen-lockfile",
		"release": "changeset publish",
		"prepack": "bun run fmt:check && bun run lint && bun run test && bun run build",
		"test": "vitest run",
		"test:ci": "VITEST_JUNIT_REPORT=true vitest run --coverage",
		"test:watch": "vitest watch",
		"test-types": "vitest run --typecheck.only --no-browser.enabled --passWithNoTests",
		"test-types:watch": "vitest watch --typecheck.only --no-browser.enabled --passWithNoTests"
	},
	"devDependencies": {
		"@changesets/changelog-github": "^0.6.0",
		"@changesets/cli": "^2.30.0",
		"@rocicorp/logger": "^5.4.0",
		"@types/bun": "^1.3.11",
		"@typescript/native-preview": "^7.0.0-dev.20260320.1",
		"@vitest/coverage-v8": "4.1.0",
		"oxfmt": "^0.41.0",
		"oxlint": "^1.56.0",
		"oxlint-tsgolint": "^0.17.1",
		"replicache": "15.3.0",
		"vitest": "4.1.0",
		"zod": "^4.3.6"
	},
	"packageManager": "bun@1.3.9"
}
